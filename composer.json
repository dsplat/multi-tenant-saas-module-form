            "priority": 300,
            "dependencies": [],
            "conflicts": [],
            "requires_core": ">=1.0.0",
            "provider": "MultiTenantSaas\\Modules\\Form\\FormServiceProvider",
            "tenant_toggleable": true,
            "default_enabled": true
        }
    }
}
